# .env.production — Variables de entorno para el build de producción (Vite)
#
# VITE_API_BASE_URL vacío significa que las llamadas a la API usan
# el mismo origen que el frontend (http://tu-app.herokuapp.com).
# Esto funciona porque FastAPI sirve tanto la API como el frontend
# desde el mismo servidor y puerto.
VITE_API_BASE_URL=
